# WoRe environment variables (optional — keys can also be set in-app via Settings).
# Copy to `.env` for local development. NEVER commit real keys.

# Used as a default/fallback AI profile. WoRe supports any OpenAI- or
# Anthropic-compatible endpoint configured per-profile in Settings.
WORE_OPENAI_API_KEY=
WORE_OPENAI_BASE_URL=https://api.openai.com/v1

# OpenRouter — used for chat + image generation models.
WORE_OPENROUTER_API_KEY=
WORE_OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
