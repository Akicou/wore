{
  "identifier": "default",
  "description": "Default capabilities for the WoRe main window.",
  "windows": ["main", "*"],
  "permissions": [
    "core:default",
    "core:webview:allow-create-webview-window",
    "core:window:allow-create",
    "core:window:allow-close",
    "core:window:allow-set-fullscreen",
    "core:window:allow-set-position",
    "core:window:allow-set-size",
    {
      "identifier": "http:default",
      "allow": [
        { "url": "http://localhost:*/*" },
        { "url": "https://localhost:*/*" },
        { "url": "http://127.0.0.1:*/*" },
        { "url": "https://127.0.0.1:*/*" },
        { "url": "http://0.0.0.0:*/*" },
        { "url": "https://*/*" }
      ]
    }
  ]
}
