{
  "identifier": "default",
  "description": "Default capabilities for the WoRe main window.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    {
      "identifier": "http:default",
      "allow": [
        { "url": "http://localhost:*/*" },
        { "url": "https://localhost:*/*" },
        { "url": "http://127.0.0.1:*/*" },
        { "url": "https://127.0.0.1:*/*" },
        { "url": "http://0.0.0.0:*/*" },
        { "url": "https://*/*" }
      ]
    }
  ]
}
